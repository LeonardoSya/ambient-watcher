    "anomaly_check_interval": 10,
    "continuous_vision_interval": 120
  },
  "analyzer": {
    "anomaly_cooldown": 60,
    "scene_change_threshold": 0.3,
    "volume_spike_threshold": 0.1
  },
  "notifier": {
    "macos_notification": true,
    "sound_on_alert": true,
    "min_interval": 5
  },
  "learner": {
    "baseline_window": 50,
    "novelty_threshold": 0.5
  }

{
  "vision": {
    "enabled": true,
    "capture_interval": 5,
    "device_name": "0",
    "width": 1280,
    "height": 720,
    "framerate": 30,
    "jpeg_quality": 5
  },
  "hearing": {
    "enabled": true,
    "sample_rate": 44100,
    "chunk_duration": 1,
    "silence_threshold": 0.01,
    "device_keyword": "MacBook"
  },
